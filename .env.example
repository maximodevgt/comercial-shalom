# Plantilla de configuración. Copiá este archivo a .env y completá los valores
# reales. El archivo .env está excluido del repo (.gitignore) y NUNCA se commitea.

# Django
# Generá una clave con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambiame-por-una-clave-secreta
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Hora local de Guatemala: los cortes de día (cierre, dashboard, reportes)
# usan timezone.localdate(); con UTC el día corta 6 horas corrido.
TIME_ZONE=America/Guatemala

# Base de datos (PostgreSQL)
DB_NAME=comercial_shalom
DB_USER=tu-usuario-de-postgres
DB_PASSWORD=tu-password-de-la-base
DB_HOST=127.0.0.1
DB_PORT=5432

# Datos del negocio (encabezado y pie de los comprobantes PDF)
NEGOCIO_NOMBRE=Comercial Shalom
NEGOCIO_DIRECCION=Ciudad Tecún Umán, Ayutla, San Marcos
